# ── VoxHub Environment Configuration ─────────────────────────────
# Copy to .env and adjust values as needed.

# HuggingFace token (required for pyannote diarization + embedding models)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Transcription model
VOXHUB_MODEL=whisper:turbo

# VAD mode: silero, pyannote, hybrid, none
VOXHUB_VAD=hybrid

# Enable speaker diarization
VOXHUB_DIARIZE=true

# API key (optional, leave empty to disable auth)
# VOXHUB_API_KEY=your-secret-key

# ── Speaker Embeddings ───────────────────────────────────────────
# Voice embeddings are biometric data. By default, VoxHub allows
# serving them over plain HTTP because the typical deployment is
# inside a Docker network where traffic never leaves the host.
#
# If VoxHub is exposed on a public or untrusted network, set this
# to false to enforce HTTPS-only for embedding endpoints.
#
# Docker network (safe):
#   VOXHUB_ALLOW_INSECURE_EMBEDDINGS=true   (default)
#
# Public / reverse-proxy without TLS termination:
#   VOXHUB_ALLOW_INSECURE_EMBEDDINGS=false
#
# Behind a TLS-terminating reverse proxy (nginx, caddy, traefik):
#   The proxy sets X-Forwarded-Proto: https, so VoxHub sees
#   the request as HTTPS regardless of this setting.
VOXHUB_ALLOW_INSECURE_EMBEDDINGS=true

# ── Voxtral vLLM backend (optional, profile: vllm) ───────────────
# Docker image for the `voxtral-vllm` service. The default works on
# stock CUDA GPUs; override when upstream wheels don't cover your
# hardware (e.g. NVIDIA Spark / GB10 Blackwell — build your own
# against the Spark CUDA base and set this to your tag).
#
# If you point at a custom image, see README → "Using a custom vLLM
# image" for the entrypoint + `mistral-common[soundfile]` gotchas.
# VOXTRAL_VLLM_IMAGE=vllm/vllm-openai:latest
